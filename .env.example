# Chatbot settings
PORT=3000

# Required for the chatbot to hit the Gemini API
GEMINI_API_KEY=your_api_key_here
# Simple shared password for accessing the chatbot frontend
BOT_PASSWORD=Test@123

# Jira Integration
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your_api_token
JIRA_PROJECT_KEY=BUG
CREATE_JIRA_TICKETS=true

# Employer Test Credentials
EMPLOYER_EMAIL=employer@example.com
EMPLOYER_PASSWORD=password123
